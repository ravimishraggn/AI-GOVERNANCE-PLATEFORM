{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://governance.platform.internal/schemas/risk-profile/v1",
  "title": "RiskProfile",
  "type": "object",
  "required": ["artifact_id", "risk_score", "risk_tier", "last_assessed"],
  "properties": {
    "artifact_id": { "type": "string", "format": "uuid" },
    "risk_score": {
      "type": "object",
      "required": ["composite", "dimensions", "confidence", "methodology"],
      "properties": {
        "composite": { "type": "number", "minimum": 0, "maximum": 10 },
        "dimensions": {
          "type": "object",
          "properties": {
            "agent_risk": { "type": "number", "minimum": 0, "maximum": 10 },
            "model_risk": { "type": "number", "minimum": 0, "maximum": 10 },
            "data_risk": { "type": "number", "minimum": 0, "maximum": 10 },
            "prompt_risk": { "type": "number", "minimum": 0, "maximum": 10 },
            "workflow_risk": { "type": "number", "minimum": 0, "maximum": 10 },
            "regulatory_risk": { "type": "number", "minimum": 0, "maximum": 10 }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "methodology": { "type": "string" }
      }
    },
    "risk_tier": {
      "type": "string",
      "enum": ["Minimal", "Low", "Moderate", "High", "Critical"]
    },
    "risk_factors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["factor_id", "domain", "description", "weight", "value"],
        "properties": {
          "factor_id": { "type": "string" },
          "domain": { "type": "string" },
          "description": { "type": "string" },
          "weight": { "type": "number" },
          "value": { "type": "number", "minimum": 0, "maximum": 10 },
          "evidence": { "type": "string" },
          "mitigatable": { "type": "boolean" }
        }
      }
    },
    "risk_acceptance": {
      "type": "object",
      "properties": {
        "accepted_by": { "type": "string" },
        "accepted_at": { "type": "string", "format": "date-time" },
        "rationale": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" },
        "conditions": { "type": "string" }
      }
    },
    "last_assessed": { "type": "string", "format": "date-time" },
    "next_review": { "type": "string", "format": "date-time" }
  }
}
